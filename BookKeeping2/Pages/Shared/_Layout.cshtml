<!DOCTYPE html>
<html lang="@UiLanguageOptions.GetHtmlLang(System.Globalization.CultureInfo.CurrentUICulture.Name)" data-bs-theme="light" data-theme-mode="system">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @SharedLocalizer["Open BookKeeping"]</title>
    <script type="importmap"></script>
    <script>
        (function () {
            const storageKey = 'bookkeeping.theme.mode';
            const allowedModes = ['light', 'dark', 'system'];

            function normalizeMode(mode) {
                return allowedModes.includes(mode) ? mode : 'system';
            }

            function systemPrefersDark() {
                try {
                    return window.matchMedia('(prefers-color-scheme: dark)').matches;
                } catch {
                    return false;
                }
            }

            function readMode() {
                try {
                    return normalizeMode(window.localStorage.getItem(storageKey));
                } catch {
                    return 'system';
                }
            }

            const mode = readMode();
            const effectiveTheme = mode === 'dark' || (mode === 'system' && systemPrefersDark()) ? 'dark' : 'light';
            const root = document.documentElement;
            root.dataset.themeMode = mode;
            root.dataset.bsTheme = effectiveTheme;
        }());
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookKeeping2.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-body-tertiary border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">@SharedLocalizer["Open BookKeeping"]</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="@SharedLocalizer["切換導覽"]">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">@SharedLocalizer["首頁"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Transactions/Index">@SharedLocalizer["明細"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Transactions/Create">@SharedLocalizer["新增"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Categories/Index">@SharedLocalizer["分類"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Accounts/Index">@SharedLocalizer["帳戶"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Reports/Index">@SharedLocalizer["報表"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Budgets/Index">@SharedLocalizer["預算"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Csv/Export">@SharedLocalizer["CSV 匯出"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Csv/Import">@SharedLocalizer["CSV 匯入"]</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Open BookKeeping
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
