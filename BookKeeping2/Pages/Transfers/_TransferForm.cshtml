@model BookKeeping2.Pages.Transfers.TransferFormPageModel

<input asp-for="Input.SubmissionToken" type="hidden" />

<div class="row g-3 mb-3 transfer-form" data-transfer-form>
    <div class="col-md-3">
        <label asp-for="Input.TransferDate" class="form-label"></label>
        <input asp-for="Input.TransferDate" class="form-control" type="date" />
        <span asp-validation-for="Input.TransferDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Input.Currency" class="form-label"></label>
        <select asp-for="Input.Currency" asp-items="Model.Options.Currencies" class="form-select" data-currency-select>
            <option value="">@SharedLocalizer["請選擇幣別"]</option>
        </select>
        <span asp-validation-for="Input.Currency" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Input.Amount" class="form-label"></label>
        <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
        <span asp-validation-for="Input.Amount" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.FromAccountId" class="form-label"></label>
        <select asp-for="Input.FromAccountId" class="form-select" data-account-select>
            <option value="">@SharedLocalizer["請選擇轉出帳戶"]</option>
            @foreach (var account in Model.Options.Accounts)
            {
                <option value="@account.Id" data-currency="@account.Currency" selected="@(account.Id == Model.Input.FromAccountId ? "selected" : null)">
                    @account.DisplayText
                </option>
            }
        </select>
        <span asp-validation-for="Input.FromAccountId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.ToAccountId" class="form-label"></label>
        <select asp-for="Input.ToAccountId" class="form-select" data-account-select>
            <option value="">@SharedLocalizer["請選擇轉入帳戶"]</option>
            @foreach (var account in Model.Options.Accounts)
            {
                <option value="@account.Id" data-currency="@account.Currency" selected="@(account.Id == Model.Input.ToAccountId ? "selected" : null)">
                    @account.DisplayText
                </option>
            }
        </select>
        <span asp-validation-for="Input.ToAccountId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Input.Note" class="form-label"></label>
        <textarea asp-for="Input.Note" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Note" class="text-danger"></span>
    </div>
</div>
