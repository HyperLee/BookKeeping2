@page "{id:long}"
@model BookKeeping2.Pages.Transfers.EditModel
@{
    ViewData["Title"] = SharedLocalizer["編輯轉帳"].Value;
}

<h1 class="h3 mb-3">@SharedLocalizer["編輯轉帳"]</h1>

<form method="post" class="bookkeeping-form" data-disable-on-submit="true">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <partial name="_TransferForm" model="Model" />
    <div class="d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-primary">@SharedLocalizer["儲存變更"]</button>
        <a class="btn btn-outline-secondary" asp-page="/Transactions/Index">@SharedLocalizer["取消"]</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
