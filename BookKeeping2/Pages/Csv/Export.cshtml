@page
@model BookKeeping2.Pages.Csv.ExportModel
@{
    ViewData["Title"] = SharedLocalizer["CSV 匯出"].Value;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="h3 mb-0">@SharedLocalizer["CSV 匯出"]</h1>
</div>

<section class="mb-4" aria-labelledby="csv-export-format-heading">
    <h2 id="csv-export-format-heading" class="h5">@SharedLocalizer["匯出格式"]</h2>
    <p class="text-muted mb-0">
        @SharedLocalizer["下載檔案固定使用七欄格式並保留原始幣別："]<code class="csv-contract-code">@Model.CurrencyCsvHeader</code>
    </p>
</section>

<section class="mb-4" aria-labelledby="transfer-csv-export-format-heading">
    <h2 id="transfer-csv-export-format-heading" class="h5">@SharedLocalizer["轉帳匯出格式"]</h2>
    <p class="text-muted mb-0">
        @SharedLocalizer["轉帳下載檔案固定使用："]<code class="csv-contract-code">@Model.TransferCsvHeader</code>
    </p>
</section>

<form method="get" asp-page-handler="Download" class="row g-3 align-items-end">
    <div class="col-12 col-md-4">
        <label class="form-label" asp-for="StartDate">@SharedLocalizer["起始日期"]</label>
        <input class="form-control" asp-for="StartDate" type="date" />
        <span class="text-danger small" asp-validation-for="StartDate"></span>
    </div>
    <div class="col-12 col-md-4">
        <label class="form-label" asp-for="EndDate">@SharedLocalizer["結束日期"]</label>
        <input class="form-control" asp-for="EndDate" type="date" />
        <span class="text-danger small" asp-validation-for="EndDate"></span>
    </div>
    <div class="col-12 col-md-4">
        <button type="submit" class="btn btn-primary w-100">@SharedLocalizer["下載 CSV"]</button>
    </div>
</form>

<form method="get" asp-page-handler="TransferDownload" class="row g-3 align-items-end mt-2">
    <div class="col-12 col-md-4">
        <label class="form-label" asp-for="StartDate">@SharedLocalizer["起始日期"]</label>
        <input class="form-control" asp-for="StartDate" type="date" />
    </div>
    <div class="col-12 col-md-4">
        <label class="form-label" asp-for="EndDate">@SharedLocalizer["結束日期"]</label>
        <input class="form-control" asp-for="EndDate" type="date" />
    </div>
    <div class="col-12 col-md-4">
        <button type="submit" class="btn btn-outline-primary w-100">@SharedLocalizer["下載轉帳 CSV"]</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
