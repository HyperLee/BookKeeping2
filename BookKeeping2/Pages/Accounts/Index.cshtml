@page
@using BookKeeping2.Models.Accounts
@model BookKeeping2.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "帳戶管理";
}

<h1 class="h3 mb-3">帳戶管理</h1>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="關閉"></button>
    </div>
}

<form method="post" class="row g-3 mb-4">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-3">
        <label asp-for="Input.Name" class="form-label"></label>
        <input asp-for="Input.Name" class="form-control" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Input.Type" class="form-label"></label>
        <select asp-for="Input.Type" class="form-select">
            <option value="@AccountType.Cash">現金</option>
            <option value="@AccountType.Bank">銀行</option>
            <option value="@AccountType.CreditCard">信用卡</option>
            <option value="@AccountType.EWallet">電子支付</option>
            <option value="@AccountType.Other">其他</option>
        </select>
    </div>
    <div class="col-md-2">
        <label asp-for="Input.OpeningBalance" class="form-label"></label>
        <input asp-for="Input.OpeningBalance" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Input.IconKey" class="form-label"></label>
        <input asp-for="Input.IconKey" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Input.DisplayOrder" class="form-label"></label>
        <input asp-for="Input.DisplayOrder" class="form-control" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">新增帳戶</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th scope="col">名稱</th>
                <th scope="col">類型</th>
                <th scope="col" class="text-end">目前餘額</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var account in Model.Accounts)
            {
                <tr>
                    <td>@account.Name</td>
                    <td>@account.TypeText</td>
                    <td class="text-end">@account.CurrentBalance.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
