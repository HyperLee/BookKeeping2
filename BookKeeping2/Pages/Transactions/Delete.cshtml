@page "{id:long}"
@model BookKeeping2.Pages.Transactions.DeleteModel
@{
    ViewData["Title"] = SharedLocalizer["刪除交易"].Value;
}

<h1 class="h3 mb-3">@SharedLocalizer["刪除交易"]</h1>

<div class="alert alert-warning" role="alert">
    @SharedLocalizer["確定要刪除此交易嗎？刪除後將不會出現在一般明細與報表中。"]
</div>

<dl class="row">
    <dt class="col-sm-3">@SharedLocalizer["日期"]</dt>
    <dd class="col-sm-9">@Model.Transaction.TransactionDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">@SharedLocalizer["類型"]</dt>
    <dd class="col-sm-9">@Model.Transaction.TypeText</dd>
    <dt class="col-sm-3">@SharedLocalizer["金額"]</dt>
    <dd class="col-sm-9">@Model.Transaction.Amount.ToString("N0")</dd>
    <dt class="col-sm-3">@SharedLocalizer["分類"]</dt>
    <dd class="col-sm-9">@Model.Transaction.CategoryName</dd>
    <dt class="col-sm-3">@SharedLocalizer["帳戶"]</dt>
    <dd class="col-sm-9">@Model.Transaction.AccountName</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">@SharedLocalizer["確認刪除"]</button>
    <a class="btn btn-outline-secondary" asp-page="/Transactions/Index">@SharedLocalizer["取消"]</a>
</form>
