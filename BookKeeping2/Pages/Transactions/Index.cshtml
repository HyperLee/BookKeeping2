@page
@model BookKeeping2.Pages.Transactions.IndexModel
@{
    ViewData["Title"] = SharedLocalizer["交易明細"].Value;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="h3 mb-0">@SharedLocalizer["交易明細"]</h1>
    <a class="btn btn-primary" asp-page="/Transactions/Create">@SharedLocalizer["新增交易"]</a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@SharedLocalizer["關閉"]"></button>
    </div>
}

<form method="get" class="row g-3 align-items-end mb-3">
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.StartDate"></label>
        <input class="form-control" asp-for="Filter.StartDate" type="date" />
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.EndDate"></label>
        <input class="form-control" asp-for="Filter.EndDate" type="date" />
        <span class="text-danger small" asp-validation-for="Filter.EndDate"></span>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.CategoryId"></label>
        <select class="form-select" asp-for="Filter.CategoryId" asp-items="Model.Options.Categories">
            <option value="">@SharedLocalizer["全部分類"]</option>
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.AccountId"></label>
        <select class="form-select" asp-for="Filter.AccountId">
            <option value="">@SharedLocalizer["全部帳戶"]</option>
            @foreach (var account in Model.Options.Accounts)
            {
                <option value="@account.Id" selected="@(account.Id == Model.Filter?.AccountId ? "selected" : null)">
                    @account.DisplayText
                </option>
            }
        </select>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.Currency"></label>
        <select class="form-select" asp-for="Filter.Currency" asp-items="Model.Options.Currencies">
            <option value="">@SharedLocalizer["全部幣別"]</option>
        </select>
        <span class="text-danger small" asp-validation-for="Filter.Currency"></span>
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.MinAmount"></label>
        <input class="form-control" asp-for="Filter.MinAmount" inputmode="decimal" />
    </div>
    <div class="col-12 col-md-3">
        <label class="form-label" asp-for="Filter.MaxAmount"></label>
        <input class="form-control" asp-for="Filter.MaxAmount" inputmode="decimal" />
        <span class="text-danger small" asp-validation-for="Filter.MaxAmount"></span>
    </div>
    <div class="col-12 col-md-4">
        <label class="form-label" asp-for="Filter.Keyword"></label>
        <input class="form-control" asp-for="Filter.Keyword" />
    </div>
    <div class="col-12 col-md-2">
        <input asp-for="Filter.PageSize" type="hidden" />
        <button type="submit" class="btn btn-outline-primary w-100">@SharedLocalizer["篩選"]</button>
    </div>
</form>

<div class="mb-2 text-muted">@SharedLocalizer["篩選結果 {0} 筆", Model.Transactions.TotalCount]</div>

@if (Model.Transactions.Items.Count == 0)
{
    <div class="alert alert-info" role="status">
        @SharedLocalizer["沒有符合條件的交易。"]
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th scope="col">@SharedLocalizer["日期"]</th>
                    <th scope="col">@SharedLocalizer["類型"]</th>
                    <th scope="col" class="text-end">@SharedLocalizer["金額"]</th>
                    <th scope="col">@SharedLocalizer["分類"]</th>
                    <th scope="col">@SharedLocalizer["帳戶"]</th>
                    <th scope="col">@SharedLocalizer["備註"]</th>
                    <th scope="col" class="text-end">@SharedLocalizer["操作"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in Model.Transactions.Items)
                {
                    <tr>
                        <td>@transaction.TransactionDate.ToString("yyyy-MM-dd")</td>
                        <td>@transaction.TypeText</td>
                        <td class="text-end"><span class="currency-amount">@transaction.AmountText</span></td>
                        <td>@transaction.CategoryName</td>
                        <td>@transaction.AccountName</td>
                        <td>@transaction.Note</td>
                        <td class="text-end transaction-actions">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Transactions/Edit" asp-route-id="@transaction.Id">@SharedLocalizer["編輯"]</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="/Transactions/Delete" asp-route-id="@transaction.Id">@SharedLocalizer["刪除"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Transactions" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
