@page
@using System.Globalization
@model BookKeeping2.Pages.Budgets.IndexModel
@{
    ViewData["Title"] = SharedLocalizer["預算管理"].Value;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h1 class="h3 mb-0">@SharedLocalizer["預算管理"]</h1>
    <form method="get" class="d-flex align-items-end gap-2">
        <div>
            <label class="form-label mb-1" asp-for="Month">@SharedLocalizer["預算月份"]</label>
            <input class="form-control" asp-for="Month" type="month" value="@Model.Month" />
            <span class="text-danger small" asp-validation-for="Month"></span>
        </div>
        <button type="submit" class="btn btn-outline-primary">@SharedLocalizer["查看"]</button>
    </form>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@SharedLocalizer["關閉"]"></button>
    </div>
}

<section aria-labelledby="budget-form-heading" class="mb-4">
    <h2 id="budget-form-heading" class="h5">@SharedLocalizer["設定分類預算"]</h2>
    <form method="post" class="row g-3 align-items-end">
        <input asp-for="Input.BudgetMonth" type="hidden" />
        <div class="col-12 col-md-4">
            <label class="form-label" asp-for="Input.CategoryId"></label>
            <select class="form-select" asp-for="Input.CategoryId">
                <option value="">@SharedLocalizer["請選擇支出分類"]</option>
                @foreach (var category in Model.Options.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
            <span class="text-danger small" asp-validation-for="Input.CategoryId"></span>
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label" asp-for="Input.Currency"></label>
            <select class="form-select" asp-for="Input.Currency" asp-items="Model.Options.Currencies">
                <option value="">@SharedLocalizer["請選擇幣別"]</option>
            </select>
            <span class="text-danger small" asp-validation-for="Input.Currency"></span>
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label" asp-for="Input.Amount"></label>
            <input class="form-control" asp-for="Input.Amount" inputmode="decimal" />
            <span class="text-danger small" asp-validation-for="Input.Amount"></span>
        </div>
        <div class="col-12 col-md-2">
            <button type="submit" class="btn btn-primary w-100">@SharedLocalizer["儲存預算"]</button>
        </div>
    </form>
</section>

<section aria-labelledby="budget-list-heading">
    <h2 id="budget-list-heading" class="h5">@SharedLocalizer["本月預算進度"]</h2>

    @if (Model.Budgets.Count == 0)
    {
        <div class="alert alert-info" role="status">@SharedLocalizer["本月尚未設定預算。"]</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle budget-table">
                <thead>
                    <tr>
                        <th scope="col">@SharedLocalizer["分類"]</th>
                        <th scope="col">@SharedLocalizer["幣別"]</th>
                        <th scope="col" class="text-end">@SharedLocalizer["預算"]</th>
                        <th scope="col" class="text-end">@SharedLocalizer["已使用"]</th>
                        <th scope="col">@SharedLocalizer["使用率"]</th>
                        <th scope="col">@SharedLocalizer["提醒"]</th>
                        <th scope="col" class="text-end">@SharedLocalizer["操作"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var budget in Model.Budgets)
                    {
                        decimal progressWidth = Math.Min(budget.UsagePercentage, 100m);
                        <tr>
                            <td>@budget.CategoryName</td>
                            <td><span class="badge text-bg-secondary">@budget.Currency</span></td>
                            <td class="text-end"><span class="currency-amount">@budget.AmountText</span></td>
                            <td class="text-end"><span class="currency-amount">@budget.SpentAmountText</span></td>
                            <td>
                                <div class="progress" role="progressbar" aria-valuenow="@budget.UsagePercentage.ToString("N2", CultureInfo.InvariantCulture)" aria-valuemin="0" aria-valuemax="100">
                                    <div class="progress-bar @budget.ProgressBarClass" style="width: @progressWidth.ToString("N2", CultureInfo.InvariantCulture)%">
                                        @budget.UsagePercentage.ToString("N2", CultureInfo.CurrentCulture)%
                                    </div>
                                </div>
                            </td>
                            <td>@budget.AlertText</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@budget.BudgetId" asp-route-month="@Model.Month">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@SharedLocalizer["刪除"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
